#!/usr/bin/env bash
set -euo pipefail

if [ -z "${SKDOS_ROOT:-}" ]; then
  SKDOS_ROOT="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
  export SKDOS_ROOT
fi

# shellcheck source=../lib/skdos-lib.sh
. "$SKDOS_ROOT/lib/skdos-lib.sh"

skdos_load_config
skdos_ensure_layout

export TERM="${TERM:-linux}"
export PATH="$SKDOS_ROOT/bin:$PATH"

clear || true
printf 'SKDos v%s\n' "$SKDOS_VERSION"
printf 'Userland root: %s\n\n' "$SKDOS_ROOT"

exec "$SKDOS_ROOT/bin/sksession"
