#!/usr/bin/env bash
set -euo pipefail

if [ -z "${SKDOS_ROOT:-}" ]; then
  SKDOS_ROOT="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
  export SKDOS_ROOT
fi

# shellcheck source=../lib/skdos-lib.sh
. "$SKDOS_ROOT/lib/skdos-lib.sh"
skdos_load_config
skdos_ensure_layout

cmd="${1:-}"
shift || true

case "$cmd" in
  roots)
    printf 'C:\\HOME    %s\n' "${SKDOS_HOME:-$SKDOS_USERS_DIR/<user>/home}"
    printf 'C:\\APPS    %s\n' "$SKDOS_APPS_DIR"
    printf 'C:\\SYSTEM  %s\n' "$SKDOS_ROOT"
    ;;
  resolve)
    skdos_fs_resolve "${1:-${SKDOS_CWD:-C:\\HOME}}"
    ;;
  list|dir)
    target="$(skdos_fs_resolve "${1:-${SKDOS_CWD:-C:\\HOME}}")"
    find "$target" -maxdepth 1 -mindepth 1 -printf '%f\n' 2>/dev/null | sort
    ;;
  type)
    if [ $# -lt 1 ]; then
      printf 'Usage: skfs type <path>\n' >&2
      exit 2
    fi
    target="$(skdos_fs_resolve "$1")"
    if [ -f "$target" ]; then
      sed -n '1,200p' "$target"
    else
      printf 'Not a file: %s\n' "$1" >&2
      exit 1
    fi
    ;;
  *)
    printf 'Usage: skfs roots|resolve|list|type [path]\n' >&2
    exit 2
    ;;
esac
