#!/usr/bin/env bash
set -euo pipefail

if [ -z "${SKDOS_ROOT:-}" ]; then
  SKDOS_ROOT="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
  export SKDOS_ROOT
fi

# shellcheck source=../lib/skdos-lib.sh
. "$SKDOS_ROOT/lib/skdos-lib.sh"
skdos_load_config
skdos_ensure_layout
skdos_task_cleanup_dead

cmd="${1:-list}"
shift || true

case "$cmd" in
  list)
    printf '%-8s %-16s %-16s %s\n' PID APP USER STARTED
    for file in "$SKDOS_TASK_DIR"/*.task; do
      [ -e "$file" ] || continue
      pid="$(awk -F= '$1 == "pid" { print $2; exit }' "$file")"
      app="$(awk -F= '$1 == "app" { print $2; exit }' "$file")"
      user="$(awk -F= '$1 == "user" { print $2; exit }' "$file")"
      started="$(awk -F= '$1 == "started" { print $2; exit }' "$file")"
      printf '%-8s %-16s %-16s %s\n' "$pid" "$app" "$user" "$started"
    done
    ;;
  kill)
    [ $# -eq 1 ] || { printf 'Usage: sktask kill <pid>\n' >&2; exit 2; }
    pid="$1"
    [ -f "$SKDOS_TASK_DIR/$pid.task" ] || { printf 'No tracked SKDos task: %s\n' "$pid" >&2; exit 1; }
    kill "$pid"
    rm -f "$SKDOS_TASK_DIR/$pid.task"
    printf 'Terminated task %s\n' "$pid"
    ;;
  *)
    printf 'Usage: sktask list|kill <pid>\n' >&2
    exit 2
    ;;
esac
