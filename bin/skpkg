#!/usr/bin/env bash
set -euo pipefail

if [ -z "${SKDOS_ROOT:-}" ]; then
  SKDOS_ROOT="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
  export SKDOS_ROOT
fi

# shellcheck source=../lib/skdos-lib.sh
. "$SKDOS_ROOT/lib/skdos-lib.sh"
skdos_load_config
skdos_ensure_layout

usage() {
  printf 'Usage: skpkg install <folder|archive> | list | remove <app>\n' >&2
}

validate_source() {
  local source_dir="$1"
  skdos_validate_manifest_dir "$source_dir"
}

install_source() {
  local source="$1"
  local work=""
  local source_dir="$source"
  local id version dest dest_real tmp="" backup=""

  if [ -f "$source" ]; then
    work="$(mktemp -d)"
    trap '[ -z "${tmp:-}" ] || rm -rf "$tmp"; [ -z "${work:-}" ] || rm -rf "$work"' EXIT
    case "$source" in
      *.tar|*.tar.gz|*.tgz)
        tar -xf "$source" -C "$work"
        ;;
      *.zip)
        command -v unzip >/dev/null 2>&1 || { printf 'unzip is required for .zip packages\n' >&2; exit 1; }
        unzip -q "$source" -d "$work"
        ;;
      *)
        printf 'Unsupported package archive: %s\n' "$source" >&2
        exit 1
        ;;
    esac
    if [ -f "$work/manifest.conf" ]; then
      source_dir="$work"
    else
      source_dir="$(find "$work" -mindepth 1 -maxdepth 1 -type d | sort | head -n 1)"
    fi
  fi

  [ -d "$source_dir" ] || { printf 'Package source not found: %s\n' "$source" >&2; exit 1; }
  validate_source "$source_dir"

  id="$(skdos_manifest_value "$source_dir/manifest.conf" id)"
  version="$(skdos_manifest_value "$source_dir/manifest.conf" version)"
  dest="$SKDOS_APPS_DIR/$id"
  dest_real="$(realpath -m "$dest")"

  case "$dest_real" in
    "$(realpath -m "$SKDOS_APPS_DIR")"/*) ;;
    *) printf 'Refusing install outside SKDos app root: %s\n' "$dest" >&2; exit 1 ;;
  esac

  if [ "$(realpath -m "$source_dir")" != "$dest_real" ]; then
    tmp="$(mktemp -d "$SKDOS_APPS_DIR/.${id}.install.XXXXXX")"
    trap '[ -z "${tmp:-}" ] || rm -rf "$tmp"; [ -z "${work:-}" ] || rm -rf "$work"' EXIT
    backup="$SKDOS_APPS_DIR/.${id}.previous.$$"
    cp -R "$source_dir"/. "$tmp"/
    skdos_validate_manifest_dir "$tmp"
    if [ -e "$dest" ]; then
      mv "$dest" "$backup"
    fi
    if mv "$tmp" "$dest"; then
      tmp=""
      rm -rf "$backup"
    else
      [ ! -e "$backup" ] || mv "$backup" "$dest"
      rm -rf "$tmp"
      printf 'Install failed; previous app was preserved: %s\n' "$id" >&2
      exit 1
    fi
  fi

  awk -F'\t' -v id="$id" '$1 != id' "$SKDOS_PACKAGE_REGISTRY" > "$SKDOS_PACKAGE_REGISTRY.tmp" || true
  mv "$SKDOS_PACKAGE_REGISTRY.tmp" "$SKDOS_PACKAGE_REGISTRY"
  printf '%s\t%s\t%s\t%s\n' "$id" "${version:-unknown}" "$dest" "$(date -Is)" >> "$SKDOS_PACKAGE_REGISTRY"

  if [ -n "$work" ]; then
    rm -rf "$work"
  fi
  trap - EXIT

  printf 'Installed %s %s\n' "$id" "${version:-unknown}"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  install)
    [ $# -eq 1 ] || { usage; exit 2; }
    install_source "$1"
    ;;
  list)
    if [ ! -s "$SKDOS_PACKAGE_REGISTRY" ]; then
      printf 'No SKDos apps installed.\n'
    else
      awk -F'\t' '{ printf "%-16s %-10s %s\n", $1, $2, $3 }' "$SKDOS_PACKAGE_REGISTRY"
    fi
    ;;
  remove)
    [ $# -eq 1 ] || { usage; exit 2; }
    app_id="$1"
    skdos_valid_id "$app_id" || { printf 'Invalid app id: %s\n' "$app_id" >&2; exit 1; }
    dest="$SKDOS_APPS_DIR/$app_id"
    [ -d "$dest" ] || { printf 'App not installed: %s\n' "$app_id" >&2; exit 1; }
    rm -rf "$dest"
    awk -F'\t' -v id="$app_id" '$1 != id' "$SKDOS_PACKAGE_REGISTRY" > "$SKDOS_PACKAGE_REGISTRY.tmp" || true
    mv "$SKDOS_PACKAGE_REGISTRY.tmp" "$SKDOS_PACKAGE_REGISTRY"
    printf 'Removed %s\n' "$app_id"
    ;;
  *)
    usage
    exit 2
    ;;
esac
